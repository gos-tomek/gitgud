---
interface Props {
  boardId: string;
}

const { boardId } = Astro.props;
const path = Astro.url.pathname;

const isImpact = path === `/board/${boardId}` || path.startsWith(`/board/${boardId}/impact`);
const isActivity = path.startsWith(`/board/${boardId}/activity`);
const isSettings = path.startsWith(`/board/${boardId}/settings`);

const base = "border-b-2 px-4 py-3 text-sm font-medium transition-colors";
const active = "border-purple-400 text-white";
const inactive = "border-transparent text-blue-100/50 hover:text-white";
---

<nav class="border-b border-white/10">
  <div class="mx-auto max-w-6xl px-4">
    <div class="flex">
      <a href={`/board/${boardId}/impact`} class:list={[base, isImpact ? active : inactive]}>Impact</a>
      <a href={`/board/${boardId}/activity`} class:list={[base, isActivity ? active : inactive]}>Activity</a>
      <a href={`/board/${boardId}/settings`} class:list={[base, isSettings ? active : inactive]}>Settings</a>
    </div>
  </div>
</nav>
