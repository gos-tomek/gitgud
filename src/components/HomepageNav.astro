---
const user = Astro.locals.user;
---

<nav class="sticky top-0 z-50 border-b border-green-100 bg-white/90 backdrop-blur-md">
  <div class="mx-auto flex h-[72px] max-w-[1120px] items-center justify-between px-8">
    <a href="/">
      <img src="/logo_gitgud.png" alt="GitGud" class="h-11 w-auto" />
    </a>
    <div class="flex items-center gap-2">
      {
        user ? (
          <>
            <a
              href="/dashboard"
              class="text-homepage-text rounded-lg px-4 py-2 text-sm font-medium transition-colors hover:bg-green-50"
            >
              Dashboard
            </a>
            <form method="POST" action="/api/auth/signout" class="inline">
              <button
                type="submit"
                class="cursor-pointer rounded-lg bg-green-600 px-5 py-2 text-sm font-semibold text-white transition-colors hover:bg-green-700"
              >
                Sign Out
              </button>
            </form>
          </>
        ) : (
          <>
            <a
              href="/auth/signin"
              class="text-homepage-text rounded-lg px-4 py-2 text-sm font-medium transition-colors hover:bg-green-50"
            >
              Sign In
            </a>
            <a
              href="/auth/signup"
              class="rounded-lg bg-green-600 px-5 py-2 text-sm font-semibold text-white transition-colors hover:bg-green-700"
            >
              Sign Up
            </a>
          </>
        )
      }
    </div>
  </div>
</nav>
