---
import "../styles/global.css";
import Banner from "@/components/Banner.astro";
import { missingConfigs } from "@/lib/config-status";
import { createClient } from "@/lib/supabase";
import { getTokenWarning } from "@/lib/token-status";

interface Props {
  title?: string;
}

const { title = "GitGud - See your contributions" } = Astro.props;

const supabase = createClient(Astro.request.headers, Astro.cookies);
const tokenWarning =
  supabase && Astro.locals.user ? await getTokenWarning(supabase, Astro.locals.user.id).catch(() => null) : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body>
    {
      missingConfigs.map((cfg) => (
        <Banner variant="error">
          <strong>Uwaga:</strong> {cfg.message}
          {cfg.docsUrl && (
            <>
              {" "}
              <a href={cfg.docsUrl} target="_blank" rel="noopener noreferrer">
                {cfg.docsLabel ?? "Dokumentacja"}
              </a>
              .
            </>
          )}
        </Banner>
      ))
    }
    {
      tokenWarning && (
        <Banner variant="warning">
          {tokenWarning.message + " "}
          <a href="/profile/settings">Update token</a>
        </Banner>
      )
    }
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
