---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { getUserBoards, getBoardContributors } from "@/lib/services/boards";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const boards = supabase && user ? await getUserBoards(supabase, user.id).catch(() => []) : [];

if (boards.length > 0) {
  const first = boards[0];
  const contributors = supabase ? await getBoardContributors(supabase, first.id).catch(() => []) : [];
  if (contributors.length > 0) {
    return Astro.redirect(`/board/${first.id}/impact/${contributors[0].githubLogin}/90d`);
  }
  return Astro.redirect(`/board/${first.id}/settings`);
}
---

<Layout title="GitGud">
  <div class="bg-background min-h-screen">
    <header class="border-border bg-background/95 sticky top-0 z-20 border-b backdrop-blur-md">
      <div class="mx-auto flex h-14 max-w-6xl items-center justify-between gap-4 px-4">
        <a href="/" class="transition-opacity hover:opacity-80">
          <img src="/logo_gitgud.png" alt="GitGud" class="h-8 w-auto" />
        </a>
        <form method="POST" action="/api/auth/signout">
          <button type="submit" class="text-muted-foreground hover:text-foreground text-sm transition-colors">
            Sign out
          </button>
        </form>
      </div>
    </header>

    <div class="flex min-h-[calc(100vh-3.5rem)] items-center justify-center p-4">
      <div class="border-border bg-card rounded-2xl border p-8 text-center shadow-sm">
        <h1 class="text-foreground mb-2 text-2xl font-bold">Welcome to GitGud</h1>
        <p class="text-muted-foreground mb-2 text-sm">You don't have any boards yet.</p>
        <p class="text-muted-foreground mb-6 text-sm">
          Your GitHub username hasn't been added as a contributor to any board yet. Ask your Supervisor to add you, or
          create your own board.
        </p>
        <a
          href="/board/new"
          class="bg-primary text-primary-foreground hover:bg-primary/90 rounded-lg px-5 py-2 text-sm font-medium"
        >
          + Create your first board
        </a>
      </div>
    </div>
  </div>
</Layout>
