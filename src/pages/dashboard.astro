---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { getUserBoards, getBoardContributors } from "@/lib/services/boards";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const boards = supabase && user ? await getUserBoards(supabase, user.id).catch(() => []) : [];

if (boards.length > 0) {
  const first = boards[0];
  const contributors = supabase ? await getBoardContributors(supabase, first.id).catch(() => []) : [];
  if (contributors.length > 0) {
    return Astro.redirect(`/board/${first.id}/impact/${contributors[0].githubLogin}/90d`);
  }
  return Astro.redirect(`/board/${first.id}/settings`);
}
---

<Layout title="GitGud">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl">
      <h1 class="mb-2 text-2xl font-bold text-white">Welcome to GitGud</h1>
      <p class="mb-6 text-sm text-blue-100/60">You don't have any boards yet.</p>
      <div class="flex flex-col items-center gap-3">
        <a
          href="/board/new"
          class="rounded-lg bg-purple-600 px-5 py-2 text-sm font-medium text-white hover:bg-purple-700"
        >
          + Create your first board
        </a>
        <form method="POST" action="/api/auth/signout">
          <button type="submit" class="text-sm text-blue-100/40 hover:text-white">Sign out</button>
        </form>
      </div>
    </div>
  </div>
</Layout>
