---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { getBoardWithRole, getBoardRepos } from "@/lib/services/boards";

const { user } = Astro.locals;
const { id } = Astro.params;

const supabase = createClient(Astro.request.headers, Astro.cookies);
const board = supabase && user && id ? await getBoardWithRole(supabase, id, user.id).catch(() => null) : null;

if (!board) {
  return Astro.redirect("/dashboard");
}

const repos = supabase ? await getBoardRepos(supabase, board.id).catch(() => []) : [];

const badgeClass = board.role === "supervisor" ? "bg-blue-500/30 text-blue-200" : "bg-purple-500/30 text-purple-200";
const badgeLabel = board.role === "supervisor" ? "Supervisor" : "Contributor";
const createdDate = new Date(board.createdAt).toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout title={board.name}>
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-lg rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <div class="mb-6 flex items-start justify-between gap-4">
        <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
          {board.name}
        </h1>
        <span class:list={["shrink-0 rounded px-2 py-0.5 text-xs font-semibold", badgeClass]}>
          {badgeLabel}
        </span>
      </div>

      <p class="mb-6 text-sm text-blue-100/50">Created {createdDate}</p>

      <div class="space-y-3">
        <div class="rounded-lg border border-white/10 bg-white/5 px-4 py-3">
          <p class="text-xs font-semibold tracking-wide text-blue-100/40 uppercase">Linked repositories</p>
          {
            repos.length === 0 ? (
              <p class="mt-1 text-sm text-blue-100/50 italic">No repositories linked</p>
            ) : (
              <ul class="mt-2 space-y-1">
                {repos.map((repo) => (
                  <li class="font-mono text-sm text-blue-100/80">
                    {repo.repoOwner}/{repo.repoName}
                  </li>
                ))}
              </ul>
            )
          }
        </div>
        <div class="rounded-lg border border-white/10 bg-white/5 px-4 py-3">
          <p class="text-xs font-semibold tracking-wide text-blue-100/40 uppercase">Contribution profiles</p>
          <p class="mt-1 text-sm text-blue-100/50 italic">Coming soon (S-04)</p>
        </div>
      </div>

      <div class="mt-6">
        <a href="/dashboard" class="text-sm text-purple-300 hover:underline"> ← Back to dashboard </a>
      </div>
    </div>
  </div>
</Layout>
