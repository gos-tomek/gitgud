---
import Layout from "@/layouts/Layout.astro";
import CreateBoardForm from "@/components/CreateBoardForm";
import { createClient } from "@/lib/supabase";
import { getUserProfile } from "@/lib/services/boards";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const profile = supabase && user ? await getUserProfile(supabase, user.id).catch(() => null) : null;

const storedPat = profile?.hasGithubPat ? { login: profile.githubPatLogin, expiresAt: profile.tokenExpiresAt } : null;
---

<Layout title="New board">
  <div class="bg-background min-h-screen">
    <header class="border-border bg-background/95 sticky top-0 z-20 border-b backdrop-blur-md">
      <div class="mx-auto flex h-14 max-w-6xl items-center justify-between gap-4 px-4">
        <a href="/dashboard" class="transition-opacity hover:opacity-80">
          <img src="/logo_gitgud.png" alt="GitGud" class="h-8 w-auto" />
        </a>
        <form method="POST" action="/api/auth/signout">
          <button type="submit" class="text-muted-foreground hover:text-foreground text-sm transition-colors">
            Sign out
          </button>
        </form>
      </div>
    </header>

    <div class="flex min-h-[calc(100vh-3.5rem)] items-center justify-center p-4">
      <div class="border-border bg-card w-full max-w-md rounded-2xl border p-8 shadow-sm">
        <h1 class="text-foreground mb-6 text-center text-2xl font-bold">New board</h1>
        <CreateBoardForm client:load storedPat={storedPat} />
        <p class="text-muted-foreground mt-4 text-center text-sm">
          <a href="/dashboard" class="text-primary hover:underline">← Back to dashboard</a>
        </p>
      </div>
    </div>
  </div>
</Layout>
