---
import Layout from "@/layouts/Layout.astro";

const isAutoConfirmed = import.meta.env.DEV;

const content = isAutoConfirmed
  ? {
      emoji: "✅",
      heading: "Registration successful",
      description: "Your account has been created. You can now sign in.",
      linkText: "Go to sign in",
    }
  : {
      emoji: "📧",
      heading: "Check your email",
      description: "We've sent a confirmation link to your email address. Click it to activate your account.",
      linkText: "Back to sign in",
    };
---

<Layout title={content.heading}>
  <div class="bg-background min-h-screen">
    <nav class="border-border bg-background/95 sticky top-0 z-50 border-b backdrop-blur-md">
      <div class="mx-auto flex h-14 max-w-6xl items-center px-4">
        <a href="/" class="transition-opacity hover:opacity-80">
          <img src="/logo_gitgud.png" alt="GitGud" class="h-8 w-auto" />
        </a>
      </div>
    </nav>

    <div class="flex min-h-[calc(100vh-3.5rem)] items-center justify-center p-4">
      <div class="border-border bg-card w-full max-w-sm rounded-2xl border p-8 text-center shadow-sm">
        <div class="mb-4 text-5xl">{content.emoji}</div>
        <h1 class="text-foreground mb-3 text-2xl font-bold">{content.heading}</h1>
        <p class="text-muted-foreground mb-6">{content.description}</p>
        <a href="/auth/signin" class="text-primary text-sm hover:underline">
          {content.linkText}
        </a>
      </div>
    </div>
  </div>
</Layout>
