---
import Layout from "@/layouts/Layout.astro";
import SignUpForm from "@/components/auth/SignUpForm";

const error = Astro.url.searchParams.get("error");
---

<Layout title="Sign up">
  <div class="bg-background min-h-screen">
    <nav class="border-border bg-background/95 sticky top-0 z-50 border-b backdrop-blur-md">
      <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-4">
        <a href="/" class="transition-opacity hover:opacity-80">
          <img src="/logo_gitgud.png" alt="GitGud" class="h-8 w-auto" />
        </a>
        <a href="/auth/signin" class="text-muted-foreground hover:text-foreground text-sm transition-colors">
          Already have an account? <span class="text-primary font-medium">Sign in</span>
        </a>
      </div>
    </nav>

    <div class="flex min-h-[calc(100vh-3.5rem)] items-center justify-center p-4">
      <div class="border-border bg-card w-full max-w-sm rounded-2xl border p-8 shadow-sm">
        <h1 class="text-foreground mb-6 text-center text-2xl font-bold">Sign up</h1>
        <SignUpForm serverError={error} client:load />
      </div>
    </div>
  </div>
</Layout>
