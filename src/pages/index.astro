---
import { env } from "cloudflare:workers";
import Homepage from "@/components/Homepage.astro";
import Layout from "@/layouts/Layout.astro";
import { logger } from "@/lib/logger";
import { createServiceClient } from "@/lib/supabase-admin";
import { getHomepageStats, type HomepageStats } from "@/lib/services/homepage-stats";

if (Astro.locals.user) {
  return Astro.redirect("/dashboard");
}

const CACHE_KEY = "homepage-stats";
const FALLBACK: HomepageStats = {
  boards: 0,
  contributors: 0,
  repos: 0,
  prsTracked: 0,
  threadsClassified: 0,
  deepDiscussions: 0,
  multiPersonThreads: 0,
  highImpactPercent: 0,
};

let stats = FALLBACK;
try {
  const cached = await env.HOMEPAGE_CACHE.get(CACHE_KEY);
  if (cached !== null) {
    stats = JSON.parse(cached) as HomepageStats;
  } else {
    const client = createServiceClient(env.SUPABASE_URL, env.SUPABASE_SERVICE_KEY);
    stats = await getHomepageStats(client);
    await env.HOMEPAGE_CACHE.put(CACHE_KEY, JSON.stringify(stats), { expirationTtl: 3600 });
  }
} catch (err) {
  logger.error("[homepage] Failed to fetch stats", err);
}
---

<Layout>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
    />
  </Fragment>
  <Homepage stats={stats} />
</Layout>
