{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gitgud",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-05-08",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "404-page",
  },
  "observability": {
    "enabled": true,
  },
  "ai": {
    "binding": "AI",
  },
  "workflows": [
    {
      "name": "classification-batch",
      "binding": "CLASSIFICATION_BATCH",
      "class_name": "ClassificationBatchWorkflow",
    },
  ],
  "triggers": {
    "crons": ["0 3 * * *"],
  },
}
